# ===== Supabase Postgres =====
# ⚠️ 현재 Supabase 무료 플랜의 "Direct connection"(db.<ref>.supabase.co)은 IPv6 전용입니다.
# 대부분의 로컬/개발 네트워크에서는 연결이 실패(UnknownHostException)하므로
# 반드시 "Session pooler"(IPv4 지원)를 사용하세요.
#
# Supabase Dashboard → Connect → Session pooler 에서 얻는 정보로 교체합니다.
#   host     : aws-0-<REGION>.pooler.supabase.com   (예: ap-northeast-2)
#   port     : 5432 (Session pooler 권장. Transaction pooler는 6543)
#   db       : postgres
#   username : postgres.<프로젝트 ref>              (예: postgres.wxkyqrduvbhawzkrxwpu)
#   password : Supabase DB 비밀번호
#
DB_URL=jdbc:postgresql://aws-0-REGION.pooler.supabase.com:5432/postgres?sslmode=require
DB_USERNAME=postgres.YOUR_PROJECT_REF
DB_PASSWORD=your-db-password

# ===== JWT (HS256) =====
SUPABASE_JWT_SECRET=replace-with-strong-random-secret
# 토큰 issuer (로컬 프론트)
SUPABASE_JWT_ISSUER=http://localhost:5173
JWT_ACCESS_TOKEN_EXP_SECONDS=86400

# ===== CORS =====
APP_CORS_ORIGINS=http://localhost:5173,https://your-frontend.onrender.com

# ===== Supabase Project / Storage =====
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
# service_role 키는 서버 전용(절대 프론트 노출 금지)
SUPABASE_SERVICE_ROLE_KEY=replace-with-service-role-jwt
SUPABASE_STORAGE_BUCKET=uploads
SUPABASE_STORAGE_PUBLIC=true

# ===== (선택) 스케줄러 cron 재정의 =====
# LETTER_VISIBILITY_CRON=0 */30 * * * *
# LETTER_CLEANUP_CRON=0 0 2 * * *
